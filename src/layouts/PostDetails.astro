---
import { render, type CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import { SITE } from "@/config";
import { getPath } from "@/utils/getPath";
import getSortedPosts from "@/utils/getSortedPosts";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
};

const { post, posts } = Astro.props;
const { title, description, pubDatetime, modDatetime, timezone, tags, category } = post.data;
const { Content } = await render(post);

const displayDate = new Date(modDatetime ?? pubDatetime).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Prev / next navigation
const sortedPosts = getSortedPosts(posts);
const currentIdx = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIdx > 0 ? sortedPosts[currentIdx - 1] : null;
const nextPost = currentIdx < sortedPosts.length - 1 ? sortedPosts[currentIdx + 1] : null;
---

<BaseLayout
  title={`${title} | ${SITE.title}`}
  description={description}
  sideBarActiveItemID="projects"
  ogType="article"
>
  <!-- Progress bar -->
  <div
    id="progress-container"
    class="fixed top-0 left-0 z-50 h-1 w-full bg-base-200 lg:left-72"
  >
    <div id="progress-bar" class="h-1 bg-primary transition-none" style="width:0%"></div>
  </div>

  <article class="post-prose">
    <!-- Title -->
    <h1 class="not-prose text-3xl font-bold leading-tight mb-3">{title}</h1>

    <!-- Meta row -->
    <div class="not-prose flex items-center gap-3 flex-wrap text-sm text-base-content/60 mb-4">
      <time>{displayDate}</time>
      {category && <span class="badge badge-outline badge-sm">{category}</span>}
    </div>

    <!-- Tags -->
    {
      tags && tags.length > 0 && (
        <div class="not-prose flex flex-wrap gap-2 mb-6">
          {tags.map(tag => (
            <a
              href={`/tags/${tag.toLowerCase().replace(/\s+/g, "-")}`}
              class="badge badge-ghost badge-sm hover:badge-primary transition-colors"
            >
              {tag}
            </a>
          ))}
        </div>
      )
    }

    <div class="divider not-prose my-4"></div>

    <!-- Post body (math + code rendering live here) -->
    <Content />
  </article>

  <!-- Prev / next -->
  <div class="divider my-8"></div>
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 not-prose">
    {
      prevPost && (
        <a
          href={getPath(prevPost.id, prevPost.filePath)}
          class="group flex items-start gap-2 hover:text-primary transition-colors"
        >
          <span class="mt-0.5 text-lg">←</span>
          <div>
            <div class="text-xs text-base-content/50 mb-1">Previous</div>
            <div class="text-sm font-medium group-hover:underline leading-snug">
              {prevPost.data.title}
            </div>
          </div>
        </a>
      )
    }
    {
      nextPost && (
        <a
          href={getPath(nextPost.id, nextPost.filePath)}
          class="group flex items-start gap-2 text-right hover:text-primary transition-colors sm:col-start-2 sm:justify-end"
        >
          <div>
            <div class="text-xs text-base-content/50 mb-1">Next</div>
            <div class="text-sm font-medium group-hover:underline leading-snug">
              {nextPost.data.title}
            </div>
          </div>
          <span class="mt-0.5 text-lg">→</span>
        </a>
      )
    }
  </div>
</BaseLayout>

<script is:inline>
  (function () {
    function updateProgress() {
      const bar = document.getElementById("progress-bar");
      if (!bar) return;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight - document.documentElement.clientHeight;
      bar.style.width = height > 0 ? (scrollTop / height) * 100 + "%" : "0%";
    }
    window.addEventListener("scroll", updateProgress, { passive: true });
    updateProgress();
  })();
</script>
