---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import HorizontalCard from "@/components/HorizontalCard.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);
    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const { tag } = Astro.params;
const { page, tagName } = Astro.props;
---

<BaseLayout title={`Tag: ${tagName} | ${SITE.title}`} sideBarActiveItemID="tags">
  <section class="mb-6">
    <a href="/tags" class="text-sm text-base-content/50 hover:text-primary transition-colors">← All Tags</a>
    <h1 class="text-3xl font-bold mt-2"># {tagName}</h1>
    <p class="text-base-content/50 text-sm mt-1">{page.total} post{page.total !== 1 ? "s" : ""}</p>
  </section>

  <div class="divide-y divide-base-200">
    {page.data.map(post => <HorizontalCard {...post} />)}
  </div>

  {page.lastPage > 1 && (
    <div class="flex justify-center items-center gap-2 mt-8">
      {page.url.prev && <a href={page.url.prev} class="btn btn-sm btn-ghost">← Prev</a>}
      <span class="text-sm text-base-content/50">{page.currentPage} / {page.lastPage}</span>
      {page.url.next && <a href={page.url.next} class="btn btn-sm btn-ghost">Next →</a>}
    </div>
  )}
</BaseLayout>
