---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/config";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";

const posts = await getCollection("blog");
const tags = getUniqueTags(posts);

const tagsWithCount = tags
  .map(({ tag, tagName }) => ({
    tag,
    tagName,
    count: getPostsByTag(posts, tag).length,
  }))
  .sort((a, b) => b.count - a.count);
---

<BaseLayout title={`Tags | ${SITE.title}`} sideBarActiveItemID="tags">
  <section class="mb-8">
    <h1 class="text-3xl font-bold mb-2">Tags</h1>
    <p class="text-base-content/60 text-sm">Browse posts by topic.</p>
  </section>

  <div class="flex flex-wrap gap-3">
    {tagsWithCount.map(({ tag, tagName, count }) => (
      <a
        href={`/tags/${tag}/`}
        class="flex items-center gap-2 px-4 py-2 rounded-lg bg-base-200/60 hover:bg-base-200 border border-base-300/50 hover:border-primary/30 transition-all group"
      >
        <span class="font-medium group-hover:text-primary transition-colors">{tagName}</span>
        <span class="text-xs text-base-content/40 tabular-nums">{count}</span>
      </a>
    ))}
  </div>
</BaseLayout>
