---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/config";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Elvin Zeynalli",
  url: SITE.website,
  image: `${SITE.website}me.jpg`,
  jobTitle: "PhD Candidate in Business Analytics & Operations Management",
  worksFor: {
    "@type": "Organization",
    name: "Sabanci University",
  },
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "Sabanci University" },
    { "@type": "CollegeOrUniversity", name: "University of Edinburgh" },
    { "@type": "CollegeOrUniversity", name: "ADA University" },
  ],
  knowsAbout: [
    "Business Analytics",
    "Quantitative Research",
    "Reinforcement Learning",
    "Machine Learning",
    "Portfolio Optimization",
    "Trading Execution",
    "Data Analysis",
    "Python",
    "SQL",
  ],
  sameAs: [
    "https://github.com/mrzeynalli",
    "https://www.linkedin.com/in/elvinzeynalli/",
    "https://mrzeynalli.medium.com/",
  ],
};
---

<BaseLayout title={`About | ${SITE.title}`} sideBarActiveItemID="about">
  <script
    slot="head"
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personSchema)}
  />
  <!-- Profile -->
  <section class="mb-10">
    <h1 class="text-3xl font-bold mb-4">About Me</h1>
    <p class="text-base-content/80 leading-relaxed max-w-2xl">
      PhD candidate in Business Analytics & Operations Management with a strong foundation in
      data-driven decision-making, quantitative research, and financial analysis. My work spans
      applied machine learning, optimization, and the application of reinforcement learning to
      trading execution and portfolio optimization. I combine academic rigor with hands-on
      experience in analytics, automation, and financial markets.
    </p>
  </section>

  <div class="divider"></div>

  <!-- Education -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">Education</h2>
    <div class="space-y-8">
      <!-- PhD -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-primary"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">PhD &mdash; Business Analytics & Operations Management</h3>
            <p class="text-sm text-base-content/60">Sabanci University, Istanbul</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Feb 2024 &mdash; Present</span>
        </div>
        <p class="text-sm mt-2 text-base-content/70">GPA: 3.58 / 4.00</p>
        <p class="text-xs mt-1 text-primary/70">Full Scholarship &mdash; Sabanci University Dean's Office</p>
        <p class="text-sm text-base-content/60 mt-2">
          Operations & Decision Analytics &middot; Data Mining &middot;
          Methods of Statistical Inference &middot; Probability & Statistics &middot;
          Stochastic Processes &middot; Dynamic Programming &middot;
          Empirical Methods in Operations Management &middot;
          Modeling in Operations Management &middot;
          Operations Research & Data Mining &middot;
          Logistics & Transportation Systems Planning
        </p>
      </div>

      <!-- MSc -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-primary"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">MSc &mdash; Business Analytics</h3>
            <p class="text-sm text-base-content/60">University of Edinburgh</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Sept 2022 &mdash; Sept 2023</span>
        </div>
        <p class="text-sm mt-2 text-base-content/70">Classification: Merit</p>
        <p class="text-xs mt-1 text-primary/70">Full State Scholarship &mdash; Ministry of Science & Education, Republic of Azerbaijan</p>
        <p class="text-sm text-base-content/60 mt-2">
          Predictive Analytics &middot; Prescriptive Analytics &middot;
          Stochastic Optimization &middot; Simulation Modelling &middot;
          Principles of Data Analytics &middot; Python Programming &middot;
          Game Theory for Business Analytics &middot;
          Web & Social Network Analytics &middot;
          Soft Computing &middot; Industrial Organisation
        </p>
      </div>

      <!-- Exchange -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-base-300"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">Exchange Semester</h3>
            <p class="text-sm text-base-content/60">ICD Business School, Paris</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Jan 2020 &mdash; May 2020</span>
        </div>
        <p class="text-xs mt-2 text-primary/70">Erasmus+ Scholarship</p>
        <p class="text-sm text-base-content/60 mt-2">
          International Finance &middot; Management of Complex Sales &middot;
          Negotiation Strategies &middot; Digital Marketing &middot;
          Business Plan &middot; Hackathon
        </p>
      </div>

      <!-- BBA -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-primary"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">BBA &mdash; Business Administration</h3>
            <p class="text-sm text-base-content/60">ADA University, Baku</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Sept 2017 &mdash; Jun 2022</span>
        </div>
        <p class="text-sm mt-2 text-base-content/70">GPA: 3.52 / 4.00</p>
        <p class="text-sm text-base-content/60 mt-2">
          Business Analytics &middot; Business Statistics I & II &middot;
          Operations Management &middot; Corporate Finance &middot;
          Financial Investments &middot; Principles of Finance &middot;
          Managerial Accounting &middot; Financial Accounting &middot;
          Management Information Systems &middot; Calculus &middot;
          Microeconomics &middot; Macroeconomics &middot;
          Strategic Management &middot; Marketing Management &middot;
          Corporate Communications &middot; Entrepreneurship
        </p>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Experience -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">Experience</h2>
    <div class="space-y-8">
      <!-- Sabanci TA -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-primary"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">Teaching Assistant</h3>
            <p class="text-sm text-base-content/60">Sabanci University, Istanbul</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Feb 2024 &mdash; Present</span>
        </div>
        <ul class="mt-2 space-y-1 text-sm text-base-content/75">
          <li>TA for Introduction to Data Analysis (MGMT 203), Introduction to Management (MGMT 201), International Business (MGMT 403), and Decision Making Under Uncertainty (OPIM 410)</li>
        </ul>
      </div>

      <!-- Chamberlain McBain -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-base-300"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">Business Development Assistant</h3>
            <p class="text-sm text-base-content/60">Chamberlain McBain, Edinburgh</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Jun 2023 &mdash; Dec 2023</span>
        </div>
        <ul class="mt-2 space-y-1 text-sm text-base-content/75">
          <li>Built a Python pipeline (web scraping &rarr; demand modelling &rarr; automated visualisation &rarr; LinkedIn outreach) that replaced two days of manual weekly work</li>
        </ul>
      </div>

      <!-- FINADCO -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-base-300"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">Junior Financial Analyst</h3>
            <p class="text-sm text-base-content/60">FINADCO, Baku</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Feb 2022 &mdash; Sept 2022</span>
        </div>
        <ul class="mt-2 space-y-1 text-sm text-base-content/75">
          <li>DCF and feasibility analyses for large investment projects; valued five government-owned assets exceeding USD 4M; authored bond market research</li>
        </ul>
      </div>

      <!-- AMFA -->
      <div class="relative pl-6 border-l-2 border-primary/30">
        <div class="absolute -left-[7px] top-1.5 w-3 h-3 rounded-full bg-base-300"></div>
        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-1">
          <div>
            <h3 class="font-bold text-lg">Communications Assistant</h3>
            <p class="text-sm text-base-content/60">Azerbaijan Micro-Finance Association, Baku</p>
          </div>
          <span class="text-sm text-base-content/50 whitespace-nowrap">Jan 2021 &mdash; Dec 2021</span>
        </div>
        <ul class="mt-2 space-y-1 text-sm text-base-content/75">
          <li>Built interactive CSR dashboards presented to board members of commercial banks and financial institutions</li>
        </ul>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Skills -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">Skills</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div>
        <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-3">Programming</h3>
        <div class="flex flex-wrap gap-2">
          <span class="badge badge-outline">Python</span>
          <span class="badge badge-outline">SQL</span>
          <span class="badge badge-outline">Git</span>
          <span class="badge badge-outline">Terminal</span>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-3">Analytics</h3>
        <div class="flex flex-wrap gap-2">
          <span class="badge badge-outline">Descriptive</span>
          <span class="badge badge-outline">Predictive</span>
          <span class="badge badge-outline">Prescriptive Modelling</span>
          <span class="badge badge-outline">Demand Forecasting</span>
          <span class="badge badge-outline">Machine Learning</span>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-3">BI / Visualisation</h3>
        <div class="flex flex-wrap gap-2">
          <span class="badge badge-outline">Power BI</span>
          <span class="badge badge-outline">Tableau</span>
          <span class="badge badge-outline">Matplotlib</span>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-semibold text-base-content/50 uppercase tracking-wider mb-3">Cloud & Databases</h3>
        <div class="flex flex-wrap gap-2">
          <span class="badge badge-outline">AWS</span>
          <span class="badge badge-outline">Azure</span>
          <span class="badge badge-outline">PostgreSQL</span>
          <span class="badge badge-outline">MongoDB</span>
        </div>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Languages -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">Languages</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="flex items-center justify-between p-3 rounded-lg bg-base-200/50">
        <span class="font-medium">Azerbaijani / Turkish</span>
        <span class="badge badge-primary badge-sm">Native</span>
      </div>
      <div class="flex items-center justify-between p-3 rounded-lg bg-base-200/50">
        <span class="font-medium">English</span>
        <span class="badge badge-primary badge-sm">Fluent</span>
      </div>
      <div class="flex items-center justify-between p-3 rounded-lg bg-base-200/50">
        <span class="font-medium">Dutch</span>
        <span class="badge badge-ghost badge-sm">Elementary</span>
      </div>
    </div>
  </section>

  <div class="divider"></div>

  <!-- Hobbies -->
  <section class="mb-10">
    <h2 class="text-2xl font-bold mb-6">Hobbies & Interests</h2>
    <div class="flex flex-wrap gap-3">
      <span class="badge badge-lg badge-ghost">Calisthenics</span>
      <span class="badge badge-lg badge-ghost">Fitness</span>
      <span class="badge badge-lg badge-ghost">Running</span>
      <span class="badge badge-lg badge-ghost">Trading</span>
      <span class="badge badge-lg badge-ghost">Philosophy</span>
      <span class="badge badge-lg badge-ghost">Politics</span>
    </div>
  </section>

  <div class="divider"></div>

  <!-- CTA -->
  <div class="text-center py-6">
    <a href="/projects" class="btn btn-primary btn-sm">View My Projects</a>
  </div>
</BaseLayout>
