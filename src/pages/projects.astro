---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import HorizontalCard from "@/components/HorizontalCard.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(allPosts);
---

<BaseLayout
  title={`Projects | ${SITE.title}`}
  description="All projects and research posts by Elvin Zeynalli."
  sideBarActiveItemID="projects"
>
  <h1 class="text-3xl font-bold mb-8">Projects</h1>

  {
    sortedPosts.map((post, i) => (
      <>
        <HorizontalCard {...post} />
        {i < sortedPosts.length - 1 && <div class="divider my-1" />}
      </>
    ))
  }
</BaseLayout>
