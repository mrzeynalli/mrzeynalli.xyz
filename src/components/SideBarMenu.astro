---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300 font-semibold";

const isActive = (id: string) => sideBarActiveItemID === id;

const base = "block w-full py-3 px-4 text-base hover:bg-base-300/50 transition-colors";
const sub  = "block w-full py-2 px-4 ps-10 text-sm text-base-content/70 hover:text-base-content hover:bg-base-300/50 transition-colors";
---

<ul class="flex flex-col py-4 gap-0.5 w-full">
  <li class="w-full">
    <a id="home" href="/" class:list={[base, { [activeClass]: isActive("home") }]}>
      Home
    </a>
  </li>

  <li class="w-full">
    <a id="projects" href="/projects" class:list={[base, { [activeClass]: isActive("projects") }]}>
      Projects
    </a>
  </li>

  <li class="w-full">
    <a id="analytics" href="/analytics" class:list={[sub, { [activeClass]: isActive("analytics") }]}>
      → Analytics
    </a>
  </li>
  <li class="w-full">
    <a id="quant-research" href="/quant-research" class:list={[sub, { [activeClass]: isActive("quant-research") }]}>
      → Quant Research
    </a>
  </li>
  <li class="w-full">
    <a id="automation" href="/automation" class:list={[sub, { [activeClass]: isActive("automation") }]}>
      → Automation
    </a>
  </li>

  <li class="w-full">
    <a id="about" href="/about" class:list={[base, { [activeClass]: isActive("about") }]}>
      Resume
    </a>
  </li>

  <li class="w-full">
    <a id="contact" href="/contact" class:list={[base, { [activeClass]: isActive("contact") }]}>
      Contact
    </a>
  </li>

  <li class="w-full">
    <a id="tags" href="/tags" class:list={[base, { [activeClass]: isActive("tags") }]}>
      Tags
    </a>
  </li>

  <li class="w-full">
    <a
      id="archives"
      href="/archives"
      class:list={["flex w-full items-center gap-2 py-3 px-4 text-base hover:bg-base-300/50 transition-colors", { [activeClass]: isActive("archives") }]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
      </svg>
      Archive
    </a>
  </li>
</ul>
