---
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300 font-semibold";

const isActive = (id: string) => sideBarActiveItemID === id;
---

<ul class="menu menu-md px-0 py-4 gap-0.5">
  <li>
    <a
      id="home"
      href="/"
      class:list={["py-3 px-4 text-base rounded-none", { [activeClass]: isActive("home") }]}
    >
      Home
    </a>
  </li>

  <li>
    <a
      id="projects"
      href="/projects"
      class:list={["py-3 px-4 text-base rounded-none", { [activeClass]: isActive("projects") }]}
    >
      Projects
    </a>
  </li>

  <!-- Sub-items under Projects -->
  <li>
    <a
      id="analytics"
      href="/analytics"
      class:list={[
        "py-2 px-4 ps-10 text-sm rounded-none text-base-content/70 hover:text-base-content",
        { [activeClass]: isActive("analytics") },
      ]}
    >
      → Analytics
    </a>
  </li>
  <li>
    <a
      id="quant-research"
      href="/quant-research"
      class:list={[
        "py-2 px-4 ps-10 text-sm rounded-none text-base-content/70 hover:text-base-content",
        { [activeClass]: isActive("quant-research") },
      ]}
    >
      → Quant Research
    </a>
  </li>
  <li>
    <a
      id="automation"
      href="/automation"
      class:list={[
        "py-2 px-4 ps-10 text-sm rounded-none text-base-content/70 hover:text-base-content",
        { [activeClass]: isActive("automation") },
      ]}
    >
      → Automation
    </a>
  </li>

  <li>
    <a
      id="about"
      href="/about"
      class:list={["py-3 px-4 text-base rounded-none", { [activeClass]: isActive("about") }]}
    >
      Resume
    </a>
  </li>

  <li>
    <a
      id="contact"
      href="/contact"
      class:list={["py-3 px-4 text-base rounded-none", { [activeClass]: isActive("contact") }]}
    >
      Contact
    </a>
  </li>

  <li>
    <a
      id="tags"
      href="/tags"
      class:list={["py-3 px-4 text-base rounded-none", { [activeClass]: isActive("tags") }]}
    >
      Tags
    </a>
  </li>

  <li>
    <a
      id="archives"
      href="/archives"
      class:list={["py-3 px-4 text-base rounded-none flex items-center gap-2", { [activeClass]: isActive("archives") }]}
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
      </svg>
      Archive
    </a>
  </li>
</ul>
