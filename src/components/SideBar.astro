---
import { Image } from "astro:assets";
import SideBarMenu from "./SideBarMenu.astro";
import SideBarFooter from "./SideBarFooter.astro";

const { sideBarActiveItemID } = Astro.props;
---

<div class="drawer-side z-40">
  <label for="my-drawer" aria-label="close sidebar" class="drawer-overlay">
    <span class="sr-only">Close sidebar</span>
  </label>
  <aside
    class="bg-base-200 min-h-screen w-72 flex flex-col"
    transition:animate="none"
  >
    <!-- Profile section -->
    <div class="px-6 pt-8 pb-4 text-center relative">
      <!-- Theme toggle -->
      <button
        id="theme-btn"
        class="absolute top-4 left-4 btn btn-ghost btn-xs btn-circle text-base-content/40 hover:text-base-content"
        aria-label="Toggle theme"
        title="Toggle light / dark"
      >
        <svg id="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>

      <!-- Search icon -->
      <a
        href="/search"
        class="absolute top-4 right-4 btn btn-ghost btn-xs btn-circle text-base-content/40 hover:text-base-content"
        aria-label="Search"
        title="Search"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </a>

      <a href="/" class="group inline-block">
        <div class="avatar">
          <div class="w-24 rounded-full ring ring-base-300 ring-offset-base-100 ring-offset-2 transition-all duration-200 group-hover:ring-primary">
            <Image src="/me.jpg" alt="Elvin Zeynalli" width={96} height={96} loading="eager" fetchpriority="high" transition:persist="avatar" />
          </div>
        </div>
      </a>
      <div class="mt-4">
        <h1 class="text-lg font-bold leading-tight">Elvin Zeynalli</h1>
        <a
          href="https://github.com/mrzeynalli"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-base-content/60 hover:text-primary transition-colors mt-1 inline-block"
        >
          @mrzeynalli
        </a>
        <p class="text-xs text-base-content/50 mt-0.5">ezeynalli@hotmail.com</p>
      </div>
    </div>

    <div class="divider my-0 px-4"></div>

    <!-- Navigation -->
    <div class="flex-1 overflow-y-auto">
      <SideBarMenu sideBarActiveItemID={sideBarActiveItemID} />
    </div>

    <div class="divider my-0 px-4"></div>

    <!-- Social icons + theme toggle -->
    <SideBarFooter />
  </aside>
</div>
